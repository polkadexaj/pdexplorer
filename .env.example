DOMAIN_NAME=explorer.polkadex.ee
LETSENCRYPT_EMAIL=admin@polkadex.ee

# Host path where the SQLite index database is stored. This is bind-mounted
# into the backend container, so the indexed blockchain data survives container
# and volume deletion. Defaults to ./data (inside the repo). Set an absolute
# path such as /var/lib/pdexplorer to keep the data outside the repo directory.
DATA_PATH=./data
