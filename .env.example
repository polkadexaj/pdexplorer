# =============================================================================
# Polkadex Explorer — environment configuration template
# =============================================================================
# Copy to .env (same directory as docker-compose.yml), edit, then:
#     docker compose up -d --build backend
#
# Every value below is OPTIONAL — server.js has sane defaults baked in. Set
# only what you want to override; leave the rest commented out.
#
# How values get picked up:
#   * Variables are read from .env by docker-compose and passed into the
#     backend container via `env_file: .env` (see docker-compose.yml).
#   * The DATA_PATH variable is ALSO interpolated by docker-compose itself
#     into the bind-mount path: ${DATA_PATH:-./data}:/app/data
#   * DOMAIN + LETSENCRYPT_EMAIL are read by init-letsencrypt.sh and by the
#     provision script too.
#
# To apply changes you must REBUILD the backend — docker-compose snapshots
# the container env at create time, so `restart` alone won't pick them up:
#     docker compose up -d --build backend
# =============================================================================

# ---- TLS / certbot ---------------------------------------------------------
DOMAIN=explorer.polkadex.ee
LETSENCRYPT_EMAIL=business@polkadex.ee
# Legacy alias accepted by init-letsencrypt.sh — same effect as DOMAIN.
# DOMAIN_NAME=explorer.polkadex.ee

# ---- Host bind mount for the SQLite index ----------------------------------
# Absolute path outside the repo is recommended; survives `docker compose down`
# and `docker volume prune`. Defaults to ./data (inside the repo).
DATA_PATH=/opt/pdexplorer/data

# ---- Polkadex RPC (chain access) -------------------------------------------
# Comma-separated WS endpoints. First = primary, rest = automatic fallback.
# When you run your own node, put it first.
POLKADEX_WS=wss://so.polkadex.ee
# Reconnect interval after a dropped socket (ms).
# POLKADEX_WS_RECONNECT_MS=2500

# ---- CORS allowlist for the API --------------------------------------------
# Comma-separated origins allowed to call /api/*. Same-origin (no Origin
# header) is always allowed regardless of this list.
ALLOWED_ORIGINS=https://explorer.polkadex.ee,http://localhost:3000

# ---- Sitemap (drives /sitemap.xml + robots.txt) ----------------------------
# Absolute URL of the public site — used for every entry in the sitemap.
SITE_URL=https://explorer.polkadex.ee
# Per-section sizes (top-N from the SQLite index):
# SITEMAP_TOP_VALIDATORS=100
# SITEMAP_RECENT_BLOCKS=200
# SITEMAP_TOP_HOLDERS=100
# SITEMAP_CACHE_TTL_MS=300000

# ---- CoinMarketCap PDEX price feed -----------------------------------------
# Get a free key at https://coinmarketcap.com/api/ — without it the price
# chart shows "Price feed not configured".
CMC_API_KEY=ee98717bf0924ab88d749ca613cd7f86
# CMC_SYMBOL=PDEX
# PRICE_SYNC_INTERVAL_MS=600000

# ---- Block / event indexer tuning ------------------------------------------
# Per-tick (every ~12s) the indexer attempts:
#   forward (BLOCKS_FORWARD_MAX)
# + backfill (BLOCKS_BACKFILL_CHUNK)
# + gap-fill (BLOCKS_GAP_FILL_CHUNK)
# blocks, in parallel batches of BLOCKS_FETCH_CONCURRENCY.
# Doubling any of these is generally safe — see the README "How to scale the
# indexer" section.
# BLOCKS_FORWARD_MAX=500
# BLOCKS_BACKFILL_CHUNK=500
# BLOCKS_GAP_FILL_CHUNK=100
# BLOCKS_FETCH_CONCURRENCY=8
# BLOCKS_MIN_BLOCK=1
# After ANY sync error, that sync's next ticks are skipped for this long
# (ms). Prevents load amplification when the RPC is timing out.
# SYNC_BACKOFF_MS=60000

# ---- Network-info / heavy queries ------------------------------------------
# Background pre-warm cadence for the home-page "Network Information" panel.
# NETWORK_INFO_REFRESH_MS=600000
# How long the cached totalUnlocking figure is fresh — the underlying full
# staking.ledger.entries() scan is the most expensive single RPC call.
# TOTAL_UNLOCKING_TTL_MS=1800000

# ---- Governance sync cadence (council / treasury / democracy) --------------
# All three default to every 5 minutes. Governance state changes over
# hours/days, not seconds — set lower only if you really need it.
# GOVERNANCE_REFRESH_MS sets the default for all three at once; the per-pallet
# vars override that default individually.
# GOVERNANCE_REFRESH_MS=300000        # 5 minutes (default)
# COUNCIL_REFRESH_MS=30000             # 30 seconds (overrides GOVERNANCE_REFRESH_MS for council)
# TREASURY_REFRESH_MS=30000
# DEMOCRACY_REFRESH_MS=30000

# ---- Staking-rewards crawler -----------------------------------------------
# How often the staking-rewards crawler ticks (forward + one backfill chunk
# each tick). Lowering this is the main lever to finish backfill faster — the
# forward pass is a no-op when the head hasn't moved, so extra ticks are
# nearly free. Combine with a larger STAKING_REWARDS_BACKFILL_CHUNK for
# multiplicative speedup.
# STAKING_REWARDS_INTERVAL_MS=30000    # default 30s; set 5000 for ~6× faster backfill
# STAKING_REWARDS_SCAN_BATCH=25
# STAKING_REWARDS_BACKFILL_CHUNK=1000  # blocks per backfill chunk; raise to walk further per tick
# STAKING_REWARDS_FORWARD_MAX=20000
# STAKING_REWARDS_MIN_BLOCK=1

# ---- Governance crawler (block-walking backfill, separate from the
#       council/treasury/democracy snapshot syncs above) ---------------------
# GOVERNANCE_INDEXER_INTERVAL_MS=30000   # default 30s
# GOV_SCAN_BATCH=50
# GOV_BACKFILL_CHUNK=2000
# GOV_FORWARD_MAX=50000
# GOV_MIN_BLOCK=1

# ---- Chain index (blocks + events) crawler ---------------------------------
# Cadence of the combined blocks + events crawler. Also controls the
# transaction-crawler partner that runs alongside it.
# CHAIN_INDEX_INTERVAL_MS=12000          # default 12s

# ---- Transactions crawler --------------------------------------------------
# TX_CACHE_LIMIT=500
# TX_INITIAL_SCAN_BLOCKS=20000
# TX_OLDER_SCAN_BLOCKS=20000
# TX_SCAN_BATCH_SIZE=25

# ---- Validator history -----------------------------------------------------
# VALIDATOR_HISTORY_ERAS=30

# ---- Wallet dashboard ------------------------------------------------------
# UNCLAIMED_TTL_MS=1200000
# TREASURY_ACCOUNT=esoEt6uZ9vs23yW8aqTACLf1tViGpSLZKnhPXt5Nq7vQwHGew

# ---- HTTP server -----------------------------------------------------------
# PORT=3001

# ---- Cluster mode ----------------------------------------------------------
# Spread HTTP serving across CPU cores. One worker (worker 1) runs both HTTP
# and the chain indexer; the rest are HTTP-only so SQLite's WAL single-writer
# invariant is preserved. The primary refork()s crashed workers, transferring
# the indexer role to the replacement if the original indexer worker died.
#
#   unset → min(cpu count, 8); sensible default for a typical VPS
#   1     → no clustering, single process (best for local dev / debug logs)
#   N     → exactly N workers, clamped to ≤16
# WORKERS=4
